---

---

<div class="form-wrapper card" id="contact-form">
  <div class="form-header">
    <h2>Request a Demo</h2>
    <p>Fill out the form and we'll schedule a personalized walkthrough within 24 hours.</p>
  </div>
  <form class="demo-form" id="demo-form" novalidate>
    <div class="form-row">
      <div class="form-group">
        <label for="fullName">Full Name <span class="required">*</span></label>
        <input type="text" id="fullName" name="fullName" placeholder="Jane Smith" required />
      </div>
      <div class="form-group">
        <label for="company">Company <span class="required">*</span></label>
        <input type="text" id="company" name="company" placeholder="Acme Corp" required />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="workEmail">Work Email <span class="required">*</span></label>
        <input type="email" id="workEmail" name="workEmail" placeholder="jane@acme.com" required />
      </div>
      <div class="form-group">
        <label for="teamSize">Team Size</label>
        <select id="teamSize" name="teamSize">
          <option value="">Select team size</option>
          <option value="1-10">1 – 10 employees</option>
          <option value="11-50">11 – 50 employees</option>
          <option value="51-200">51 – 200 employees</option>
          <option value="201-500">201 – 500 employees</option>
          <option value="500+">500+ employees</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="useCase">Primary Use Case</label>
        <select id="useCase" name="useCase">
          <option value="">What's your main goal?</option>
          <option value="attendance">Attendance & Shift Tracking</option>
          <option value="leave">Leave & Approval Management</option>
          <option value="payroll">Payroll Readiness</option>
          <option value="onboarding">Employee Onboarding</option>
          <option value="analytics">Workforce Analytics</option>
          <option value="all">Full HR Operations</option>
        </select>
      </div>
      <div class="form-group">
        <label for="phone">Phone <span class="optional">(optional)</span></label>
        <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000" />
      </div>
    </div>
    <div class="form-group">
      <label for="message">Additional Details</label>
      <textarea id="message" name="message" rows="3" placeholder="Tell us about your team's current challenges or what you're looking for..."></textarea>
    </div>
    <button type="submit" class="btn btn-primary btn-lg form-submit" id="form-submit">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      Submit Demo Request
    </button>
    <p class="form-disclaimer">By submitting, you agree to our privacy policy. We typically respond within one business day.</p>
  </form>

  <!-- Success state -->
  <div class="form-success" id="form-success" style="display:none;">
    <div class="success-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
    </div>
    <h3>Thank you for your interest!</h3>
    <p>We've received your demo request and will reach out within <strong>24 hours</strong> to schedule your personalized walkthrough of StaffOne.</p>
    <a href="/" class="btn btn-secondary">Back to Home</a>
  </div>
</div>

<script is:inline>
  (function() {
    const form = document.getElementById('demo-form');
    const success = document.getElementById('form-success');
    const submit = document.getElementById('form-submit');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const nameInput = document.getElementById('fullName');
      const emailInput = document.getElementById('workEmail');
      const companyInput = document.getElementById('company');

      if (!nameInput?.value?.trim() || !emailInput?.value?.trim() || !companyInput?.value?.trim()) {
        return;
      }

      if (submit) {
        submit.disabled = true;
        submit.innerHTML = '<span class="spinner"></span> Submitting...';
      }

      // Prepare JSON data for Backend API
      const formData = new FormData(form);
      const dataPayload = {
        fullName: formData.get('fullName'),
        company: formData.get('company'),
        workEmail: formData.get('workEmail'),
        teamSize: formData.get('teamSize'),
        useCase: formData.get('useCase'),
        message: formData.get('message')
      };

      try {
        const apiUrl = import.meta.env.PUBLIC_API_URL;
        if (!apiUrl) {
          throw new Error('CRITICAL: PUBLIC_API_URL is not defined in environment variables.');
        }

        const response = await fetch(`${apiUrl}/api/v1/public/demo-request`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(dataPayload)
        });

        const data = await response.json();

        if (data.success) {
          const wrapper = document.querySelector('.form-wrapper');
          if (form) form.style.display = 'none';
          const header = wrapper?.querySelector('.form-header');
          if (header) header.style.display = 'none';
          if (success) success.style.display = 'flex';
        } else {
          alert("Something went wrong. Please try again.");
          if (submit) {
            submit.disabled = false;
            submit.innerHTML = 'Submit Demo Request';
          }
        }
      } catch (error) {
        console.error('Error submitting form:', error);
        alert("Network error. Please check your connection and try again.");
        if (submit) {
          submit.disabled = false;
          submit.innerHTML = 'Submit Demo Request';
        }
      }
    });
  })();
</script>

<style>
  .form-wrapper {
    padding: var(--space-10);
  }

  .form-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .form-header h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .form-header p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .demo-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .required {
    color: var(--error);
  }

  .optional {
    font-weight: 400;
    color: var(--text-tertiary);
    font-size: var(--text-xs);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--brand-start);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-submit {
    width: 100%;
    margin-top: var(--space-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .form-submit svg {
    flex-shrink: 0;
  }

  .form-disclaimer {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  /* Spinner */
  .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Success state */
  .form-success {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-5);
    padding: var(--space-12) var(--space-8);
  }

  .success-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(16, 185, 129, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--success);
    animation: successPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes successPop {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .form-success h3 {
    font-size: var(--text-xl);
  }

  .form-success p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 400px;
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .form-wrapper { padding: var(--space-6); }
  }
</style>
