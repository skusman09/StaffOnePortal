---
interface Props {
  title: string;
  subtitle: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const { title, subtitle, primaryCTA, secondaryCTA } = Astro.props;
---

<section class="cta-banner">
  <div class="container">
    <div class="cta-inner">
      <div class="cta-glow"></div>
      <div class="cta-content">
        <h2 class="cta-title">{title}</h2>
        <p class="cta-subtitle">{subtitle}</p>
        <div class="cta-actions">
          {primaryCTA && (
            <a href={primaryCTA.href} class="btn btn-lg" style="background:white;color:#4f46e5;font-weight:700;">
              {primaryCTA.label}
            </a>
          )}
          {secondaryCTA && (
            <a href={secondaryCTA.href} class="btn btn-lg" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.2);">
              {secondaryCTA.label}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding: var(--space-20) 0;
  }

  .cta-inner {
    position: relative;
    background: var(--brand-gradient);
    border-radius: var(--radius-2xl);
    padding: var(--space-16) var(--space-8);
    text-align: center;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    color: white;
    margin-bottom: var(--space-4);
  }

  .cta-subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 520px;
    margin: 0 auto var(--space-8);
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .cta-actions {
      flex-direction: column;
    }
    .cta-actions .btn {
      width: 100%;
    }
  }
</style>
