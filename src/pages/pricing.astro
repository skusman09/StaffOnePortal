---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCards from '../components/PricingCards.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';

const plans = [
  {
    name: 'Starter',
    price: { monthly: 4, annual: 3 },
    description: 'For small teams getting started with attendance and leave tracking.',
    cta: 'Start Free Trial',
    features: [
      'Up to 25 employees',
      'GPS-verified attendance tracking',
      'Multi-shift support (regular, OT, break)',
      'Leave management with balances',
      'Holiday calendar',
      'Employee self-service portal',
      'Basic reports and CSV export',
      'Email support',
    ],
  },
  {
    name: 'Professional',
    price: { monthly: 9, annual: 7 },
    description: 'Full workforce management with payroll, onboarding, and analytics.',
    cta: 'Start Free Trial',
    highlight: true,
    badge: 'Most Popular',
    features: [
      'Up to 200 employees',
      'Everything in Starter, plus:',
      'Automated payroll generation',
      'CTC breakdowns and deductions',
      'Structured onboarding workflows',
      'Comp-off request and approval',
      'Pulse surveys for team sentiment',
      'Analytics dashboard with trends',
      'Audit trail and compliance logs',
      'Department and location management',
      'Priority email and chat support',
    ],
  },
  {
    name: 'Enterprise',
    price: { monthly: 0, annual: 0 },
    description: 'Dedicated infrastructure, SLAs, and advanced compliance for large organizations.',
    cta: 'Contact Sales',
    features: [
      'Unlimited employees',
      'Everything in Professional, plus:',
      'SSO / SAML authentication',
      'Custom role definitions',
      'Multi-location geofencing',
      'Advanced compliance reporting',
      'Dedicated account manager',
      'Custom SLA guarantees',
      'API access for custom integrations',
      'On-premise deployment option',
      'Phone and video support',
    ],
  },
];

const faqs = [
  {
    question: 'Is there a free trial available?',
    answer: 'Yes. Both Starter and Professional plans include a 14-day free trial with full feature access. No credit card required to start.',
  },
  {
    question: 'Can I switch plans later?',
    answer: 'Absolutely. You can upgrade or downgrade your plan at any time. Upgrades take effect immediately, and downgrades apply at the end of your current billing cycle. No penalties.',
  },
  {
    question: 'What happens when I exceed my employee limit?',
    answer: "We'll notify you when you're approaching your plan's employee cap. You can either upgrade to the next tier or contact us for a custom arrangement that fits your growth trajectory.",
  },
  {
    question: 'Do you offer annual billing discounts?',
    answer: 'Yes. Annual billing saves approximately 22% compared to monthly billing. You can switch between monthly and annual at any time.',
  },
  {
    question: 'What payment methods do you accept?',
    answer: 'We accept all major credit cards (Visa, Mastercard, American Express), wire transfers for Enterprise plans, and can accommodate purchase orders for organizations with procurement processes.',
  },
  {
    question: 'Is my data secure?',
    answer: 'StaffOne uses encrypted data storage, JWT-based authentication with token rotation, role-based access controls, rate limiting, and immutable audit trails. We follow industry-standard security practices and are built on SOC 2-ready infrastructure.',
  },
  {
    question: 'Can I export my data?',
    answer: 'Yes. All plans include CSV export for attendance records, employee data, payroll reports, and analytics. Enterprise customers also have API access for programmatic data extraction.',
  },
  {
    question: 'Do you provide onboarding support?',
    answer: 'Starter and Professional plans include documentation and email support. Enterprise customers receive dedicated onboarding assistance, training sessions, and a named account manager.',
  },
];
---

<BaseLayout title="Pricing" description="StaffOne pricing — transparent plans that scale with your team. Start free, upgrade when ready.">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-content reveal">
        <span class="badge badge-brand">Pricing</span>
        <h1>Plans that <span class="gradient-text">grow with your team</span></h1>
        <p>No hidden fees. No per-module charges. Choose the plan that matches your team's operational complexity.</p>
      </div>

      <!-- Billing Toggle -->
      <div class="billing-toggle reveal delay-1">
        <span class="toggle-label active" id="monthly-label">Monthly</span>
        <button class="toggle-switch" id="billing-toggle" aria-label="Toggle billing period" type="button">
          <span class="toggle-knob"></span>
        </button>
        <span class="toggle-label" id="annual-label">
          Annual
          <span class="toggle-save">Save 22%</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pricing-section">
    <div class="container reveal">
      <PricingCards plans={plans} />
    </div>
  </section>

  <!-- Enterprise CTA -->
  <section class="section section-alt">
    <div class="container">
      <div class="enterprise-cta card card-hover reveal">
        <div class="enterprise-content">
          <h2>Need a custom plan?</h2>
          <p>For organizations with 200+ employees, on-premise requirements, or specific compliance needs, we offer tailored Enterprise agreements with dedicated support and custom SLAs.</p>
        </div>
        <div class="enterprise-actions">
          <a href="/contact" class="btn btn-primary btn-lg">Talk to Sales</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">FAQ</span>
        <h2>Frequently asked questions</h2>
        <p>Everything you need to know about StaffOne pricing and plans.</p>
      </div>
      <div class="reveal">
        <FAQ items={faqs} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Start your 14-day free trial"
    subtitle="No credit card required. Full feature access. Set up in under 15 minutes."
    primaryCTA={{ label: 'Start Free Trial', href: '/contact' }}
    secondaryCTA={{ label: 'Request a Demo', href: '/contact' }}
  />

</BaseLayout>

<script is:inline>
  (function() {
    const billingToggle = document.getElementById('billing-toggle');
    const monthlyLabel = document.getElementById('monthly-label');
    const annualLabel = document.getElementById('annual-label');
    let isAnnual = false;

    billingToggle?.addEventListener('click', () => {
      isAnnual = !isAnnual;
      billingToggle.classList.toggle('active', isAnnual);
      monthlyLabel?.classList.toggle('active', !isAnnual);
      annualLabel?.classList.toggle('active', isAnnual);

      document.querySelectorAll('.pricing-amount').forEach(el => {
        const monthly = el.getAttribute('data-monthly');
        const annual = el.getAttribute('data-annual');
        if (!monthly) return;
        el.textContent = isAnnual ? annual : monthly;
      });
    });
  })();
</script>

<style>
  .page-hero {
    padding: var(--space-20) 0 var(--space-8);
    text-align: center;
  }

  .page-hero-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: var(--space-4) 0;
  }

  .page-hero p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
  }

  /* Billing toggle */
  .billing-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .toggle-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .toggle-label.active {
    color: var(--text-primary);
  }

  .toggle-save {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
  }

  .toggle-switch {
    width: 48px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    position: relative;
    transition: background var(--transition-fast);
    cursor: pointer;
  }

  .toggle-switch.active {
    background: var(--brand-start);
    border-color: var(--brand-start);
  }

  .toggle-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    transition: transform var(--transition-fast);
    box-shadow: var(--shadow-sm);
  }

  .toggle-switch.active .toggle-knob {
    transform: translateX(20px);
  }

  .pricing-section {
    padding: var(--space-12) 0 var(--space-20);
  }

  /* Enterprise CTA */
  .enterprise-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    background: var(--bg-card);
    border-radius: var(--radius-2xl);
    padding: var(--space-8) var(--space-10); /* Override standard card padding layout */
  }

  .enterprise-content h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .enterprise-content p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    max-width: 520px;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .enterprise-cta {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
