---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Testimonials from '../components/Testimonials.astro';
import CTABanner from '../components/CTABanner.astro';

const features = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    title: 'Attendance & Shift Tracking',
    description: 'GPS-verified check-in and check-out with support for regular, overtime, and break shifts. Real-time live duration tracking and geofence validation.',
    highlight: true,
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
    title: 'Leave & Comp-off Management',
    description: 'Submit, review, and approve leave requests across leave types. Automated balance calculations, comp-off workflows, and holiday calendar management.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
    title: 'Payroll Readiness',
    description: 'Automated salary computation from attendance data with CTC breakdowns, deductions, and tax handling. Export-ready payroll inputs for any pay period.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Employee Onboarding',
    description: 'Structured checklist-driven onboarding workflows. Track task completion per new hire, ensure nothing slips through the cracks, and monitor progress in real time.',
    highlight: true,
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/></svg>',
    title: 'Department & Location Management',
    description: 'Organize employees by department and location. Multi-site operations with geofenced attendance boundaries and department-level visibility.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
    title: 'Analytics & Reporting',
    description: 'Admin dashboards with top performer rankings, attendance trends, leave breakdowns, and per-employee performance analytics. Exportable CSV reports.',
  },
];

const howItWorks = [
  { step: '01', title: 'Set Up Your Org', desc: 'Define departments, locations, shifts, and holiday calendars. Configure attendance, leave, and payroll policies in minutes.' },
  { step: '02', title: 'Onboard Your Team', desc: 'Invite employees with role-based access. Use structured onboarding checklists to get new hires productive from day one.' },
  { step: '03', title: 'Track & Manage', desc: 'Employees check in and out with GPS verification. Managers approve leaves, review comp-offs, and monitor attendance.' },
  { step: '04', title: 'Analyze & Act', desc: 'Get real-time analytics on workforce performance, attendance patterns, and payroll readiness. Make data-driven HR decisions.' },
];

const benefits = [
  { role: 'For HR Managers', items: ['Centralized employee data and records', 'Automated attendance and leave tracking', 'Payroll-ready reports with zero manual work', 'Pulse surveys to gauge team sentiment'] },
  { role: 'For Team Leads', items: ['Instant visibility into team attendance', 'Approve or deny leave requests in seconds', 'Track overtime and shift compliance', 'Onboarding checklist management'] },
  { role: 'For Employees', items: ['One-tap check-in with live duration tracking', 'Self-service leave applications', 'Transparent salary breakdowns and history', 'Personal attendance reports and calendar views'] },
];

const testimonials = [
  {
    quote: 'StaffOne replaced three separate tools we were using for attendance, leave management, and payroll prep. The onboarding checklists alone saved us weeks per quarter.',
    name: 'Priya Sharma',
    role: 'HR Director',
    company: 'TechScale Solutions',
    initials: 'PS',
    color: '#4f46e5',
  },
  {
    quote: 'The shift tracking is exactly what we needed for our multi-location operations. GPS-verified check-ins give us confidence that attendance data is accurate.',
    name: 'Marcus Chen',
    role: 'Operations Manager',
    company: 'GridPoint Logistics',
    initials: 'MC',
    color: '#3b82f6',
  },
  {
    quote: 'Our managers finally have real visibility into team performance. The analytics dashboard surfaces patterns we never had access to before.',
    name: 'Amira Hassan',
    role: 'VP People Ops',
    company: 'Beacon Health',
    initials: 'AH',
    color: '#6366f1',
  },
];

const integrations = ['Slack', 'Google Workspace', 'Microsoft 365', 'Zoho', 'QuickBooks', 'Xero', 'BambooHR', 'Zapier'];
---

<BaseLayout title="StaffOne" description="StaffOne — Workforce management built for modern teams. Centralize HR, track attendance, streamline payroll, and manage employees across locations.">

  <!-- Hero -->
  <Hero
    title='Workforce operations,<br/> <span class="gradient-text">unified and visible.</span>'
    subtitle="Centralize attendance, leave, payroll, and onboarding into a single platform. Give managers real-time visibility, give employees self-service tools, and keep HR operations audit-ready."
    primaryCTA={{ label: 'Request a Demo', href: '/contact' }}
    secondaryCTA={{ label: 'Explore Features', href: '/features' }}
  />

  <!-- Trust Strip -->
  <section class="trust-strip section-alt">
    <div class="container">
      <div class="trust-metrics reveal">
        <div class="trust-metric">
          <span class="trust-number">99.9%</span>
          <span class="trust-label">Platform Uptime</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-metric">
          <span class="trust-number">50K+</span>
          <span class="trust-label">Check-ins Processed Daily</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-metric">
          <span class="trust-number">40%</span>
          <span class="trust-label">Reduction in HR Admin Time</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-metric">
          <span class="trust-number">24h</span>
          <span class="trust-label">Average Onboarding Time</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Overview -->
  <section class="section" id="features-overview">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">Core Modules</span>
        <h2>Everything your team needs to operate efficiently</h2>
        <p>StaffOne consolidates attendance, leave, payroll, onboarding, and analytics into a single platform — so your operations never fragment across disconnected tools.</p>
      </div>
      <div class="grid-3 features-grid">
        {features.map((f, i) => (
          <div class={`reveal delay-${(i % 3) + 1}`}>
            <FeatureCard icon={f.icon} title={f.title} description={f.description} highlight={f.highlight} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">How It Works</span>
        <h2>Go live in under an hour</h2>
        <p>From initial setup to full team adoption, StaffOne is designed to be operational fast — without training overhead or complex migrations.</p>
      </div>
      <div class="steps-grid reveal">
        {howItWorks.map((item) => (
          <div class="step-card">
            <div class="step-number">{item.step}</div>
            <h3 class="step-title">{item.title}</h3>
            <p class="step-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits by Role -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">Role-Based Value</span>
        <h2>Built for every layer of your organization</h2>
        <p>StaffOne delivers value to HR teams, managers, and individual employees — each with tailored workflows and visibility.</p>
      </div>
      <div class="grid-3 reveal">
        {benefits.map((b) => (
          <div class="benefit-card card">
            <h3 class="benefit-role">{b.role}</h3>
            <ul class="benefit-list">
              {b.items.map(item => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">Testimonials</span>
        <h2>Trusted by operations-driven teams</h2>
        <p>See why growing teams choose StaffOne to standardize their workforce operations.</p>
      </div>
      <div class="reveal">
        <Testimonials testimonials={testimonials} />
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="section" id="integrations">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">Integrations</span>
        <h2>Works with your existing stack</h2>
        <p>StaffOne connects with the tools your team already uses — from communication platforms to accounting software.</p>
      </div>
      <div class="integrations-row reveal">
        {integrations.map((name) => (
          <div class="integration-pill">
            <div class="integration-dot"></div>
            {name}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Teaser -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header reveal">
        <span class="badge badge-brand">Pricing</span>
        <h2>Transparent plans that scale with your team</h2>
        <p>No hidden fees, no per-module charges. Choose the plan that fits your team size and operational needs.</p>
      </div>
      <div class="pricing-teaser reveal">
        <div class="teaser-cards">
          <div class="teaser-card card">
            <h3>Starter</h3>
            <p class="teaser-price">$4<span>/user/mo</span></p>
            <p class="teaser-desc">For small teams getting started with attendance and leave tracking.</p>
          </div>
          <div class="teaser-card card teaser-highlight">
            <span class="teaser-badge">Most Popular</span>
            <h3>Professional</h3>
            <p class="teaser-price">$9<span>/user/mo</span></p>
            <p class="teaser-desc">Full workforce management with payroll, onboarding, and analytics.</p>
          </div>
          <div class="teaser-card card">
            <h3>Enterprise</h3>
            <p class="teaser-price">Custom</p>
            <p class="teaser-desc">Dedicated support, SLAs, SSO, and advanced compliance features.</p>
          </div>
        </div>
        <div class="teaser-cta">
          <a href="/pricing" class="btn btn-secondary btn-lg">View Full Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <CTABanner
    title="Ready to centralize your workforce operations?"
    subtitle="Schedule a personalized demo and see how StaffOne can transform your team's daily operations."
    primaryCTA={{ label: 'Request a Demo', href: '/contact' }}
    secondaryCTA={{ label: 'View Pricing', href: '/pricing' }}
  />

</BaseLayout>

<style>
  /* Trust Strip */
  .trust-strip {
    padding: var(--space-10) 0;
  }

  .trust-metrics {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-10);
    flex-wrap: wrap;
  }

  .trust-metric {
    text-align: center;
  }

  .trust-number {
    display: block;
    font-size: var(--text-3xl);
    font-weight: 900;
    background: var(--brand-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .trust-label {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-top: var(--space-1);
    display: block;
  }

  .trust-divider {
    width: 1px;
    height: 48px;
    background: var(--border-primary);
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .step-card {
    text-align: center;
    padding: var(--space-6);
  }

  .step-number {
    font-size: var(--text-4xl);
    font-weight: 900;
    background: var(--brand-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-4);
  }

  .step-title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .step-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Benefits */
  .benefit-card {
    padding: var(--space-8);
  }

  .benefit-role {
    font-size: var(--text-lg);
    margin-bottom: var(--space-5);
    background: var(--brand-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .benefit-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .benefit-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .benefit-list svg {
    flex-shrink: 0;
  }

  /* Integrations */
  .integrations-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .integration-pill {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .integration-pill:hover {
    border-color: var(--brand-start);
    box-shadow: var(--shadow-sm);
  }

  .integration-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
  }

  /* Pricing Teaser */
  .teaser-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .teaser-card {
    text-align: center;
    padding: var(--space-8);
    position: relative;
  }

  .teaser-highlight {
    border-color: var(--brand-start);
    box-shadow: var(--shadow-brand);
  }

  .teaser-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand-gradient);
    color: white;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .teaser-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .teaser-price {
    font-size: var(--text-3xl);
    font-weight: 900;
    margin-bottom: var(--space-3);
  }

  .teaser-price span {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--text-tertiary);
  }

  .teaser-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .teaser-cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .teaser-cards { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto var(--space-8); }
  }

  @media (max-width: 768px) {
    .trust-divider { display: none; }
    .trust-metrics { gap: var(--space-6); }
    .steps-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }
</style>
